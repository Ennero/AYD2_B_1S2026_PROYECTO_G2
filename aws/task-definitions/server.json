{
  "family": "logitrans-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::163381207900:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::163381207900:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "logitrans-server",
      "image": "163381207900.dkr.ecr.us-east-1.amazonaws.com/logitrans/server:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",          "value": "production" },
        { "name": "PORT",              "value": "3000" },
        { "name": "DB_LOGGING",        "value": "false" },
        { "name": "DB_AUTO_SEED",      "value": "true" },
        { "name": "DB_RESET_ON_BOOT",  "value": "false" },
        { "name": "CORS_ORIGINS",                "value": "https://guatechnology.com" },
        { "name": "SUPABASE_BUCKET_SIGNATURES",  "value": "signatures" },
        { "name": "SUPABASE_BUCKET_EVIDENCE",    "value": "evidence" },
        { "name": "SUPABASE_BUCKET_LOGS",        "value": "logs" },
        { "name": "SUPABASE_BUCKET_INVOICES",    "value": "invoices" },
        { "name": "SES_FROM_EMAIL",              "value": "hello@guatechnology.com" },
        { "name": "SES_FROM_NAME",               "value": "LogiTrans" },
        { "name": "PORTAL_URL",                  "value": "https://guatechnology.com" }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_HOST"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_PORT"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_USERNAME"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_PASSWORD"
        },
        {
          "name": "DB_DATABASE",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_DATABASE"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/JWT_SECRET"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/RESEND_API_KEY"
        },
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/SUPABASE_URL"
        },
        {
          "name": "SUPABASE_SERVICE_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/SUPABASE_SERVICE_KEY"
        },
        {
          "name": "RABBITMQ_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/RABBITMQ_URL"
        },
        {
          "name": "DB_REPLICA_HOST",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_REPLICA_HOST"
        },
        {
          "name": "DB_REPLICA_PORT",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_REPLICA_PORT"
        },
        {
          "name": "DB_REPLICA_USERNAME",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_REPLICA_USERNAME"
        },
        {
          "name": "DB_REPLICA_ENABLED",
          "valueFrom": "arn:aws:ssm:us-east-1:<ACCOUNT_ID>:parameter/logitrans/prod/DB_REPLICA_ENABLED"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/logitrans-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:3000/api/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
