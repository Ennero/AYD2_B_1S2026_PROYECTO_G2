{
  "__inputs": [
    {
      "name": "DS_INFLUXDB-K6",
      "label": "InfluxDB-k6",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "panel",   "id": "graph",   "name": "Graph",   "version": "" },
    { "type": "panel",   "id": "stat",    "name": "Stat",    "version": "" },
    { "type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "LogiTrans k6 Load & Stress Test Results",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT mean(\"value\") FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 500 }] }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto" },
      "title": "p95 Response Time",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto" },
      "title": "Active VUs",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT last(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "title": "Requests / sec",
      "type": "stat",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT mean(\"value\") FROM \"http_reqs\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Response Time Distribution (p50 / p90 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 50) AS \"p50\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "p50" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 90) AS \"p90\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "p90" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "p95" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 99) AS \"p99\" FROM \"http_req_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "p99" }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "title": "Active VUs over time",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT mean(\"value\") FROM \"vus\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "title": "Error Rate over time",
      "type": "timeseries",
      "targets": [{ "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT mean(\"value\") FROM \"http_req_failed\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "A" }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 8,
      "title": "Response Time by Endpoint (custom trends)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) FROM \"health_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "health" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) FROM \"login_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "login" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) FROM \"orders_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "orders" },
        { "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB-K6}" }, "query": "SELECT percentile(\"value\", 95) FROM \"response_duration\" WHERE $timeFilter GROUP BY time($__interval) fill(0)", "refId": "stress_response" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "load-testing", "logitrans"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LogiTrans — k6 Load Testing Results",
  "uid": "logitrans-k6",
  "version": 1
}
