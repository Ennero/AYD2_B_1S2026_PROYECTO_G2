# ============================================================================
# Database Configuration
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=logitrans_db

# Automatically seed database on first run
DB_AUTO_SEED=true

# DANGER: Drop and recreate schema on boot (for development only)
DB_RESET_ON_BOOT=false

# ============================================================================
# Server Configuration
# ============================================================================

# Port the NestJS server listens on
PORT=3000

# Environment: development, staging, production
NODE_ENV=development

# JWT Secret for signing authentication tokens
# IMPORTANT: Change this in production to a strong random string
JWT_SECRET=your_jwt_secret_key_here

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed origins (no spaces)
# Examples: http://localhost:3000,http://app.example.com,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ============================================================================
# Logging Configuration
# ============================================================================

# Enable SQL query logging
DB_LOGGING=true

# ============================================================================
# Resend — Email Notifications
# ============================================================================

# API Key obtenida en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Dirección remitente — debe pertenecer a un dominio verificado en Resend.
# Durante desarrollo puedes usar: onboarding@resend.dev (solo envía a tu cuenta)
SES_FROM_EMAIL=noreply@logitrans.com
# Nombre visible del remitente en los clientes de correo
SES_FROM_NAME=LogiTrans

# URL pública del portal web (se incluye en los correos como enlace de acción)
PORTAL_URL=http://localhost:3001

# ============================================================================
# Notes
# ============================================================================
# - For local development: Use defaults
# - For Docker Compose: Override with environment variables or .env.production
# - For Kubernetes: Use ConfigMaps and Secrets
# - Resend sandbox: verifica tu dominio en resend.com/domains para enviar
#   a cualquier destinatario. Sin dominio verificado usa onboarding@resend.dev.
