{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["**/integration/**/*.spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "./tsconfig.json"
    }]
  },
  "setupFiles": ["<rootDir>/setup/integration-env.js"],
  "testTimeout": 30000
}
